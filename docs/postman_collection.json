{
    "info": {
        "name": "Collector.shop API",
        "description": "Postman Collection for the Collector.shop Microservices API.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://collector.local/api",
            "type": "string"
        },
        {
            "key": "token",
            "value": "YOUR_JWT_TOKEN_HERE",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Article Service",
            "item": [
                {
                    "name": "Get All Articles",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/articles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "articles"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Article by ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/articles/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "articles",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Create Article",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Vintage Comic\",\n  \"description\": \"First edition comic book\",\n  \"price\": 150.00,\n  \"category\": \"Comics\",\n  \"condition\": \"mint\",\n  \"images\": [\"url1.jpg\"],\n  \"sellerId\": \"uuid\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/articles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "articles"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Article",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Vintage Comic (Updated)\",\n  \"price\": 180.00\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/articles/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "articles",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Article",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/articles/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "articles",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "User Service",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"username\": \"johndoe\",\n  \"displayName\": \"John Doe\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/users/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Login User",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/users/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Profile (Self)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/users/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "profile"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"displayName\": \"John Doe Jr.\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/users/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "profile"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Public Profile by ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/users/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Payment Service",
            "item": [
                {
                    "name": "Initiate Payment",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"articleId\": \"uuid\",\n  \"buyerId\": \"uuid\",\n  \"amount\": 150.00\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/payments/initiate",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payments",
                                "initiate"
                            ]
                        }
                    }
                },
                {
                    "name": "Complete Payment",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payments/:id/complete",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payments",
                                ":id",
                                "complete"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Payment History by User",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payments/user/:userId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payments",
                                "user",
                                ":userId"
                            ],
                            "variable": [
                                {
                                    "key": "userId",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Payment Detail",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payments/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payments",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "uuid"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ]
}