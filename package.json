{
    "name": "collector-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "services/*"
    ],
    "scripts": {
        "prepare": "if [ -z \"$CI\" ]; then husky; fi",
        "test": "npm run test --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present"
    },
    "devDependencies": {
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0"
    },
    "lint-staged": {
        "*.{js,ts,vue,json,md}": "echo 'Linting file...'"
    },
    "overrides": {
        "@nestjs/cli": {
            "glob": "^10.5.0"
        }
    }
}